# Copy this file to .env and adjust values as needed.

# PostgreSQL connection string.
# For local Docker dev this matches docker-compose.yml.
DATABASE_URL="postgresql://minisass:minisass@localhost:5434/minisass?schema=public"

# Secret used to sign JWT auth tokens. Must be at least 32 characters.
# Generate a strong value with `openssl rand -base64 32`.
JWT_SECRET="change-me-to-a-long-random-string"
